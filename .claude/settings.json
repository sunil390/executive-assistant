{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/bootstrap.sh", "timeout": 3000 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ritual-check.sh", "timeout": 3000 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/mode-context.sh", "timeout": 2000 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill|Agent|Task",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/filter-skills-by-mode.sh", "timeout": 2000 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-pending-debriefs.sh", "timeout": 2000 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enter-review-mode.sh", "timeout": 2000 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill|Agent|Task",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/touch-projects.sh", "timeout": 2000 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/scan-commitments.sh", "timeout": 2000 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/promise-detector.sh", "timeout": 2000 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/project-mention-tracker.sh", "timeout": 2000 }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/preserve-crm.sh", "timeout": 3000 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/eod-snapshot.sh", "timeout": 5000 }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(jq:*)",
      "Bash(date:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)"
    ]
  }
}
